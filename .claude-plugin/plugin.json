{
  "name": "kaho",
  "description": "Kaho companion plugin — gives Claude a virtual avatar face with emotions, expressions, and chat",
  "version": "1.1.0",
  "author": {
    "name": "Scott Yu"
  },
  "homepage": "https://kaho.scottyu.ca",
  "repository": "https://github.com/scottyu3/kaho-plugin",
  "license": "MIT",
  "keywords": ["kaho", "avatar", "companion", "emotions", "mcp"],
  "mcpServers": {
    "kaho": {
      "command": "npx",
      "args": ["-y", "kaho-mcp-server"],
      "env": {
        "KAHO_SERVER_URL": "https://kaho.scottyu.ca",
        "KAHO_ID": "",
        "KAHO_API_KEY": ""
      }
    }
  }
}
